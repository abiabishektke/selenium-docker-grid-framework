<?xml version="1.0" encoding="UTF-8"?>
<extentreports>
    <configuration>

        <!-- Theme -->
        <theme>DARK</theme>

        <!-- Report Details -->
        <documentTitle>Automation Execution Report</documentTitle>
        <reportName>Selenium Hybrid Framework Report</reportName>

        <!-- Time Format -->
        <timeStampFormat>EEEE, MMMM dd, yyyy, hh:mm a</timeStampFormat>

        <!-- Encoding -->
        <encoding>UTF-8</encoding>

        <!-- Protocol -->
        <protocol>https</protocol>

        <!-- Timeline -->
        <timelineEnabled>true</timelineEnabled>

        <!-- Custom CSS (Optional) -->
        <css>
            <![CDATA[
                .nav-logo {
                    width: 200px;
                }
            ]]>
        </css>

        <!-- Custom JS (Optional) -->
        <js>
            <![CDATA[
                console.log('Extent Report Loaded Successfully');
            ]]>
        </js>

    </configuration>
</extentreports>